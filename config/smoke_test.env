#!/usr/bin/env bash

PIPELINE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_ROOT="$PIPELINE_ROOT"
SAMPLES_TSV="$PIPELINE_ROOT/config/smoke_samples.tsv"
DATA_DIR="$PIPELINE_ROOT/smoke_test/data"
OUTPUT_DIR="$PIPELINE_ROOT/smoke_test/output"
LOG_DIR="$PIPELINE_ROOT/smoke_test/logs"
ANNOTATION_DIR="$PIPELINE_ROOT/smoke_test/annotation"
ANNOTATION_FUNCTIONAL_DIR="$PIPELINE_ROOT/smoke_test/annotation_functional"

# shellcheck disable=SC1091
source "$PIPELINE_ROOT/config/pipeline.env"

SMOKE_TEST_MODE=1
ENABLE_ANNOTATION=1
ENABLE_BUSCO_PLOT=1
ENABLE_INTERPROSCAN=1
ANNOTATION_SAMPLE_ID="0339"

SUPERNOVA_ARRAY_CONCURRENCY=1
MKOUTPUT_ARRAY_CONCURRENCY=1
FILTER_ARRAY_CONCURRENCY=1
BUSCO_ARRAY_CONCURRENCY=1
REPEATMODELER_ARRAY_CONCURRENCY=1
REPEATMASKER_ARRAY_CONCURRENCY=1

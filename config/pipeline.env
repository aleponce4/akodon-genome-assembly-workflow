#!/usr/bin/env bash

# Resolve the repo root from this config file so the pipeline can be moved
# without rewriting every path by hand.
PIPELINE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_ROOT="${PROJECT_ROOT:-$PIPELINE_ROOT}"

SAMPLES_TSV="${SAMPLES_TSV:-$PIPELINE_ROOT/config/samples.tsv}"
ASSEMBLY_PREFIX="${ASSEMBLY_PREFIX:-akodon}"
SUPERNOVA_RUN_ID_PREFIX="${SUPERNOVA_RUN_ID_PREFIX:-supernova_akodon}"
SUPERNOVA_MKOUTPUT_STYLE="${SUPERNOVA_MKOUTPUT_STYLE:-pseudohap2}"
PRIMARY_HAPLOTYPE="${PRIMARY_HAPLOTYPE:-1}"
SUPERNOVA_MAXREADS="${SUPERNOVA_MAXREADS:-1000000000}"
MIN_SCAFFOLD_BP="${MIN_SCAFFOLD_BP:-10000}"
REPEATMASKER_SPECIES="${REPEATMASKER_SPECIES:-rodentia}"
CD_HIT_IDENTITY="${CD_HIT_IDENTITY:-0.80}"
CD_HIT_WORD_SIZE="${CD_HIT_WORD_SIZE:-10}"
CD_HIT_MEMORY_MB="${CD_HIT_MEMORY_MB:-30000}"

DATA_DIR="${DATA_DIR:-$PROJECT_ROOT/data}"

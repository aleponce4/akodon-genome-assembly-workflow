REPEAT_FAMILY_EXPORT_DIR="${REPEAT_FAMILY_EXPORT_DIR:-$REPEATMODELER_DIR/repeat_database_fa_files}"
REPEAT_LIBRARY_DIR="${REPEAT_LIBRARY_DIR:-$REPEATMODELER_DIR/final_files}"

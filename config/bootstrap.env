#!/usr/bin/env bash

PIPELINE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_ROOT="$PIPELINE_ROOT"

# shellcheck disable=SC1091
source "$PIPELINE_ROOT/config/pipeline.env"

BOOTSTRAP_DIR="${BOOTSTRAP_DIR:-$PROJECT_ROOT/bootstrap}"
BOOTSTRAP_CACHE_DIR="${BOOTSTRAP_CACHE_DIR:-$BOOTSTRAP_DIR/cache}"
BOOTSTRAP_STATUS_TSV="${BOOTSTRAP_STATUS_TSV:-$BOOTSTRAP_DIR/status.tsv}"
BOOTSTRAP_SUMMARY_TXT="${BOOTSTRAP_SUMMARY_TXT:-$BOOTSTRAP_DIR/summary.txt}"

BUSCO_LINEAGE_NAME="${BUSCO_LINEAGE_NAME:-glires_odb10}"

FILTER_CONDA_PACKAGES="${FILTER_CONDA_PACKAGES:-seqkit}"
BUSCO_CONDA_PACKAGES="${BUSCO_CONDA_PACKAGES:-busco}"
MULTIQC_CONDA_PACKAGES="${MULTIQC_CONDA_PACKAGES:-multiqc}"
REPEAT_CONDA_PACKAGES="${REPEAT_CONDA_PACKAGES:-cd-hit seqkit}"
QUAST_CONDA_PACKAGES="${QUAST_CONDA_PACKAGES:-quast}"
DATASETS_CONDA_PACKAGES="${DATASETS_CONDA_PACKAGES:-ncbi-datasets-cli}"

# Bundled in the repo under job_scripts/bin; override only if you want to replace it.
HEADER_SIMPLIFIER_SOURCE="${HEADER_SIMPLIFIER_SOURCE:-}"
# Default helper source from the public TSEBRA repository.
LONGEST_ISOFORM_SCRIPT_SOURCE="${LONGEST_ISOFORM_SCRIPT_SOURCE:-https://raw.githubusercontent.com/Gaius-Augustus/TSEBRA/main/bin/get_longest_isoform.py}"

SUPERNOVA_ARCHIVE_SOURCE="${SUPERNOVA_ARCHIVE_SOURCE:-}"
# Optional local copy source for a discontinued Supernova install.
SUPERNOVA_MANUAL_PATH="${SUPERNOVA_MANUAL_PATH:-}"
REPEATMODELER_IMAGE_SOURCE="${REPEATMODELER_IMAGE_SOURCE:-docker://dfam/tetools:latest}"
BRAKER_IMAGE_SOURCE="${BRAKER_IMAGE_SOURCE:-}"
GALBA_IMAGE_SOURCE="${GALBA_IMAGE_SOURCE:-}"
# Pinned to the version documented in the current InterProScan container guide.
INTERPROSCAN_IMAGE_SOURCE="${INTERPROSCAN_IMAGE_SOURCE:-docker://interpro/interproscan:5.77-108.0}"
INTERPROSCAN_DATA_ARCHIVE_SOURCE="${INTERPROSCAN_DATA_ARCHIVE_SOURCE:-http://ftp.ebi.ac.uk/pub/software/unix/iprscan/5/5.77-108.0/alt/interproscan-data-5.77-108.0.tar.gz}"

# These remain manual by default because they are project-specific biological inputs.
TSEBRA_CONFIG_SOURCE_DIR="${TSEBRA_CONFIG_SOURCE_DIR:-}"
# These three defaults populate annotation/input/tsebra_config_1.cfg .. _3.cfg.
TSEBRA_CONFIG_1_SOURCE="${TSEBRA_CONFIG_1_SOURCE:-https://raw.githubusercontent.com/Gaius-Augustus/TSEBRA/main/config/default.cfg}"
TSEBRA_CONFIG_2_SOURCE="${TSEBRA_CONFIG_2_SOURCE:-https://raw.githubusercontent.com/Gaius-Augustus/TSEBRA/main/config/braker3.cfg}"
TSEBRA_CONFIG_3_SOURCE="${TSEBRA_CONFIG_3_SOURCE:-https://raw.githubusercontent.com/Gaius-Augustus/TSEBRA/main/config/keep_ab_initio.cfg}"
BRAKER3_PROTEIN_FASTA_SOURCE="${BRAKER3_PROTEIN_FASTA_SOURCE:-}"
NCBI_DATASETS_TSV_SOURCE="${NCBI_DATASETS_TSV_SOURCE:-}"

NCBI_DATASETS_BIN="${NCBI_DATASETS_BIN:-$DATASETS_ENV_PREFIX/bin/datasets}"
